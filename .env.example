# TreloLabs Voice AI — Environment Configuration
# ================================================
# Copy this file to `.env` and fill in your values.
# Never commit `.env` to version control.
#
# Research Provenance:
#   - 12-Factor App methodology: config stored in environment, not files [^88].
#   - OWASP: secrets in env vars reduce exposure vs hardcoded credentials [^89].
#   - Twilio Media Streams require TLS in production [^43].

# ---------------------------------------------------------------------------
# Application Mode
# ---------------------------------------------------------------------------
# DEMO_MODE=true skips Azure OpenAI / Redis validation and runs the local
# CPU pipeline (faster-whisper + MockLLM + Piper). Ideal for sales demos
# without cloud API keys [^16].
DEMO_MODE=true

APP_ENV=dev
LOG_LEVEL=info
PORT=8000

# ---------------------------------------------------------------------------
# TreloLabs Branding
# ---------------------------------------------------------------------------
COMPANY_NAME=TreloLabs Voice AI
BUSINESS_HOURS="Monday through Friday, 8 AM to 6 PM. Emergency dispatch 24/7."

# ---------------------------------------------------------------------------
# Azure OpenAI (Production LLM)
# ---------------------------------------------------------------------------
# Ref: ADR-005; OpenAI Function Calling API [^13].
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-06-01

# ---------------------------------------------------------------------------
# Deepgram (Alternative STT/TTS)
# ---------------------------------------------------------------------------
# Ref: Deepgram Nova-3 streaming ASR [^61]; Aura TTS [^9].
DEEPGRAM_API_KEY=your-deepgram-api-key

# ---------------------------------------------------------------------------
# Sarvam Bulbul v3 (Telugu / Indic TTS — ADR-019 dual-TTS routing)
# ---------------------------------------------------------------------------
# When SARVAM_API_KEY is set, Telugu-preference parents are routed to
# Sarvam's Bulbul v3 instead of Deepgram Aura. Unset → graceful
# fall-through to Aura (Aura cannot pronounce Telugu but the deployment
# stays operational). Optional: SARVAM_TELUGU_SPEAKER picks a specific
# Bulbul v3 voice; default "gokul". Speaker roster in
# src/infrastructure/sarvam_tts_client.py.
SARVAM_API_KEY=your-sarvam-api-key
# Speaker — see roster in src/infrastructure/sarvam_tts_client.py
# Default for Suryapet: female warm voice. Alternates: priya, shruti, kavya.
SARVAM_TELUGU_SPEAKER=kavitha
# Pace 0.5-2.0 (default 0.95 — slightly slower than 1.0 for dignified Telangana register).
# Per-call pace match (Communication Accommodation) overrides this dynamically.
SARVAM_PACE=0.95
# Temperature 0.01-2.0 (default 0.7 — slight expressive variation without prosodic drift).
SARVAM_TEMPERATURE=0.7
# Optional pronunciation dictionary ID (Bulbul v3 only).
# Register a dict via the Sarvam dashboard or Pronunciation Dictionary API
# to fix proper-noun mispronunciations (Aarav, Suryapet, etc.).
SARVAM_DICT_ID=

# ---------------------------------------------------------------------------
# Twilio Telephony
# ---------------------------------------------------------------------------
# Ref: Twilio Media Streams API [^43]; Fielding REST thesis [^79].
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER=+1234567890

# ---------------------------------------------------------------------------
# Redis Cache
# ---------------------------------------------------------------------------
# Ref: Redis persistence best practices. AOF + LRU for session cache.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_KEY=
REDIS_SSL=false

# ---------------------------------------------------------------------------
# Azure Infrastructure
# ---------------------------------------------------------------------------
SEARCH_ENDPOINT=https://your-search.search.windows.net
SEARCH_KEY=your-search-key
SEARCH_INDEX_NAME=faq-knowledge-base

STORAGE_CONNECTION_STRING=your-storage-connection-string
BLOB_CONTAINER_RECORDINGS=recordings
BLOB_CONTAINER_FAQ=faq-documents

APPLICATIONINSIGHTS_CONNECTION_STRING=your-appinsights-connection-string

# ---------------------------------------------------------------------------
# Model Paths (Demo Pipeline)
# ---------------------------------------------------------------------------
# Faster-Whisper auto-downloads to ~/.cache/faster-whisper on first run.
# Piper models should be placed in models/piper/.
PIPER_MODEL_PATH=./models/piper/en_US-lessac-medium.onnx
PIPER_MODEL_CONFIG=./models/piper/en_US-lessac-medium.onnx.json

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
OTEL_SERVICE_NAME=trelolabs-voice-agent
PROMETHEUS_PORT=9090

# ---------------------------------------------------------------------------
# Domain (Production)
# ---------------------------------------------------------------------------
# Ref: ADR-006 — subdomain architecture for SaaS voice products [^82][^84].
PUBLIC_DOMAIN=voice.trelolabs.com

# References
# [^13]: OpenAI. (2023). Function Calling API Documentation.
# [^16]: SigArch. (2026). Building Enterprise Realtime Voice Agents from Scratch.
# [^43]: Twilio. (2024). Media Streams API Documentation.
# [^61]: Deepgram. (2024). Nova-3 Streaming ASR Documentation.
# [^79]: Fielding, R. T. (2000). Architectural Styles and the Design of Network-based Software Architectures.
# [^82]: Google. (2019). Search Engine Optimization (SEO) Starter Guide.
# [^84]: Fielding, R. T. (2000). REST architectural style.
# [^88]: Wiggins, A. (2017). The Twelve-Factor App. 12factor.net.
# [^89]: OWASP. (2023). Secrets Management Cheat Sheet. owasp.org.
